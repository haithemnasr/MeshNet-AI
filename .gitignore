# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── ML model weights (large binaries — tracked via Git LFS or excluded) ──────
models/**/*.zip
models/**/*.pt
models/**/*.pth
models/**/tensorboard/
# Keep placeholder notes
!models/**/.gitkeep

# ── Data & results ────────────────────────────────────────────────────────────
# Keep pre-generated comparison charts committed; ignore anything auto-regenerated

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
.env
